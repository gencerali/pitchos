[{"title":"Beşiktaş'ta elde kaldı kupa!","summary":"Haberler Spor Futbol Süper Lig Beşiktaş Beşiktaş&#039;ta elde kaldı kupa! - Beşiktaş Haberleri Beşiktaş'ta elde kaldı kupa! Trendyol Süper Lig&#039;in 28. haftasında Fenerbahçe ile deplasmanda karşı karşıya gelen Beşiktaş, son anda penaltıdan yediği golle derbiyi 1-0 kaybetti. Bitime 6 hafta kala 3.","full_body":"Haberler Spor Futbol Süper Lig Beşiktaş Beşiktaş&#039;ta elde kaldı kupa! - Beşiktaş Haberleri Beşiktaş'ta elde kaldı kupa! Trendyol Süper Lig&#039;in 28. haftasında Fenerbahçe ile deplasmanda karşı karşıya gelen Beşiktaş, son anda penaltıdan yediği golle derbiyi 1-0 kaybetti. Bitime 6 hafta kala 3.","source":"Habertürk Spor","url":"https://www.haberturk.com/besiktas-ta-elde-kaldi-kupa-3875138-spor","category":"Club","nvs":85,"golden_score":5,"time_ago":"2 saat önce","is_fresh":true,"sport":"football","publish_mode":"copy_source","image_url":"https://im.haberturk.com/l/2026/04/06/ver1775464363/3875138/jpg/1200x628"},{"title":"Fenerbahçe evinde Beşiktaş'ı 90+11'de devirdi! İşte maçın özeti","summary":"Haberler Fenerbah&#231;e Haberleri Fenerbahçe evinde Beşiktaş'ı 90+11'de devirdi! İşte maçın özeti Fenerbahçe evinde Beşiktaş'ı 90+11'de devirdi! İşte maçın özeti Trendyol Süper Lig'in 28. haftasında Fenerbahçe ile Beşiktaş kozlarını paylaştı. Çekişmeli derbide gülen taraf 1-0'lık skorla sarı lacive","full_body":"Haberler Fenerbah&#231;e Haberleri Fenerbahçe evinde Beşiktaş'ı 90+11'de devirdi! İşte maçın özeti Fenerbahçe evinde Beşiktaş'ı 90+11'de devirdi! İşte maçın özeti Trendyol Süper Lig'in 28. haftasında Fenerbahçe ile Beşiktaş kozlarını paylaştı. Çekişmeli derbide gülen taraf 1-0'lık skorla sarı lacive","source":"A Spor","url":"https://www.aspor.com.tr/fenerbahce/2026/04/05/fenerbahce-evinde-besiktasi-son-anlarda-devirdi-iste-macin-ozeti","category":"Haber","nvs":85,"golden_score":5,"time_ago":"Güncel","is_fresh":true,"sport":"football","publish_mode":"copy_source","image_url":"https://iaaspr.tmgrup.com.